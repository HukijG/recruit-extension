# Copy this file to BOTH:
#   .env.development  — used by `plasmo dev`
#   .env.production   — used by `plasmo build`

# --- Middleware (always required) ---
# Full origin: scheme + host (+ port). No trailing slash. The Cloudflare
# Worker that fronts Recruiterflow + Dialpad. The extension never talks to
# Dialpad or Recruiterflow directly — the worker serves the
# /dialpad-user-context and /dialpad-call contracts.
PLASMO_PUBLIC_MIDDLEWARE_URL=https://your-worker.workers.dev

# --- Music worker (required for the now-playing bar) ---
# Full origin: scheme + host (+ port). No trailing slash. The SEPARATE,
# DEDICATED Cloudflare Worker that fronts the office music remote — both the
# /music/* HTTP control + search routes AND the now-playing WebSocket
# (/music/now-playing) target this base. Distinct from the Recruiterflow /
# Dialpad middleware above; auth is the same extension scheme (X-Extension-Token
# / CF Access JWT).
PLASMO_PUBLIC_MUSIC_URL=https://your-music-worker.workers.dev
