# Copy this file to BOTH:
#   .env.development  — used by `plasmo dev`
#   .env.production   — used by `plasmo build`

# --- Middleware (always required) ---
# Full origin: scheme + host (+ port). No trailing slash. The Cloudflare
# Worker that fronts Recruiterflow + Dialpad. The extension never talks to
# Dialpad or Recruiterflow directly — the worker serves the
# /dialpad-user-context and /dialpad-call contracts.
PLASMO_PUBLIC_MIDDLEWARE_URL=https://your-worker.workers.dev

# --- OAuth (App 2 — Cloudflare Access SaaS-OIDC) ---
# CF Access tenant. No trailing slash.
PLASMO_PUBLIC_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
# Client ID captured at App 2 creation (UUID-like).
PLASMO_PUBLIC_ACCESS_CLIENT_ID=
# Audience tag — exact value the worker has as ACCESS_AUD_MIDDLEWARE.
PLASMO_PUBLIC_ACCESS_AUDIENCE=
# Base64 public key for stable extension ID. Generate once:
#   openssl genrsa -out key.pem 2048
#   openssl rsa -in key.pem -pubout -outform DER | openssl base64 -A
CRX_PUBLIC_KEY=
